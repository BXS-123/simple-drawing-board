<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.huabu.mapper.WorkMapper">
    <select id="findByUserId" resultType="com.example.huabu.entity.Work">
        SELECT * FROM works WHERE user_id = #{userId} ORDER BY updated_at DESC
    </select>
</mapper>